# Plantilla de variables de entorno del widget.
# Copiar a .env.development / .env.staging / .env.production según ambiente.
# Ver docs/VARIABLES_DE_ENTORNO.md y docs/EMBED-POLARIA.md.

# Webhook n8n del canal web Mateo (Bearer JWT widget — POL-71/72).
VITE_N8N_WEBHOOK_URL=

# Cloudinary — unsigned upload de imágenes adjuntas.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
