# Plantilla de variables de entorno del widget. Copiar a .env.staging /
# .env.production (Vite las carga automáticamente según --mode) con los
# valores reales de cada ambiente antes de desplegar — ver docs/ENTORNOS.md.

# URL del webhook de n8n que procesa los mensajes del widget (workflow
# correspondiente a este ambiente: staging o producción).
VITE_N8N_WEBHOOK_URL=

# Cloud name de la cuenta de Cloudinary de este ambiente.
VITE_CLOUDINARY_CLOUD_NAME=

# Upload preset (unsigned) de Cloudinary de este ambiente — antes de usarlo,
# confirmar en la consola de Cloudinary sus límites de formato/tamaño (ver
# checklist de Fase 2).
VITE_CLOUDINARY_UPLOAD_PRESET=
