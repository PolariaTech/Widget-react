# Valores de desarrollo local (npm run dev / build sin --mode). No son
# secretos de build (el preset de Cloudinary es unsigned por diseño, y la
# URL del webhook no puede ocultarse en una app cliente de todos modos —
# ver docs/SEGURIDAD.md), así que este archivo sí se versiona. La
# autenticación de cada llamada al webhook va en el header Authorization
# en tiempo de ejecución (src/lib/authToken.ts), no en esta URL.
VITE_N8N_WEBHOOK_URL=https://polariatech.app.n8n.cloud/webhook/test-mateo-support
VITE_CLOUDINARY_CLOUD_NAME=ujssaxx6
VITE_CLOUDINARY_UPLOAD_PRESET=mateo_test_unsigned
